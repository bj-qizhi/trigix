POSTGRES_USER=agentflow
POSTGRES_PASSWORD=agentflow
POSTGRES_DB=agentflow
POSTGRES_HOST=localhost
POSTGRES_PORT=35432

REDIS_HOST=localhost
REDIS_PORT=36380

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:39000
MINIO_BUCKET=agentflow

CREDENTIAL_MASTER_KEY=replace-with-32-byte-base64-key

PLATFORM_HTTP_ADDR=127.0.0.1:38080
EXECUTOR_HTTP_ADDR=127.0.0.1:38090
AI_RUNTIME_HTTP_ADDR=127.0.0.1:38070

# Set to enable Platform → standalone Executor routing
EXECUTOR_BASE_URL=http://127.0.0.1:38090

# Set to enable Agent node execution via AI Runtime
AI_RUNTIME_BASE_URL=http://127.0.0.1:38070

# Required for Agent node execution
ANTHROPIC_API_KEY=sk-ant-...

# Distributed execution queue (Redis Streams). When true, the platform pushes
# jobs to a stream and a worker drains them. Failed/poison jobs are routed to a
# dead-letter stream (inspect via GET /v1/system/queue-depth and
# GET /v1/admin/dlq; re-drive via POST /v1/admin/dlq/requeue).
USE_QUEUE=false

# Data retention (Postgres only). Opt-in: when > 0, a background sweeper deletes
# executions / node-executions / audit-log / token-usage / webhook-deliveries
# older than this many days. Unset or 0 disables it.
DATA_RETENTION_DAYS=0
# How often the retention sweeper runs, in seconds (default 21600 = 6h).
DATA_RETENTION_SWEEP_SECS=21600

# Enterprise SSO (OIDC). Externally-reachable platform base URL — used to build
# the IdP redirect_uri ({PUBLIC_BASE_URL}/v1/sso/:slug/callback). Register this
# callback at your IdP (Okta / Azure AD / Google Workspace).
PUBLIC_BASE_URL=http://localhost:38080
# SPA base URL the callback hands the session token back to (?sso_token=...).
FRONTEND_URL=http://localhost:3100
# JWT_SECRET signs both session tokens and the SSO CSRF state — set a strong
# value in production.
JWT_SECRET=dev-secret-change-in-production
